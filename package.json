{
  "name": "annual-cycle",
  "version": "1.0.0",
  "description": "Årshjul – annual cycle tracker for recurring tasks",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.iframe.config.js",
    "preview": "vite preview",
    "notify": "node src/notify.js",
    "notify:debug": "DRY_RUN=1 NOTIFY_PERIOD=all node src/notify.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
